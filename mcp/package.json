{
  "name": "@scihan/career-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Public, owner-maintained, read-only career evidence MCP server for Selçuk Cihan.",
  "scripts": {
    "generate:data": "tsx scripts/generate-public-profile.ts ../candidate-profile.yaml",
    "types": "wrangler types",
    "types:check": "wrangler types --check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test": "npm run test:unit && npm run test:worker",
    "dev": "npm run generate:data && wrangler dev",
    "bundle:check": "wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "check": "npm run generate:data && npm run types:check && npm run typecheck && npm run lint && npm test && npm run bundle:check",
    "deploy": "npm run check && wrangler deploy",
    "smoke:remote": "tsx scripts/smoke-remote.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.18.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.7",
    "@eslint/js": "10.0.1",
    "@types/node": "24.10.11",
    "ajv": "8.20.0",
    "eslint": "10.7.0",
    "tsx": "4.23.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10",
    "wrangler": "4.113.0",
    "yaml": "2.9.0"
  },
  "engines": {
    "node": ">=22.18"
  }
}
